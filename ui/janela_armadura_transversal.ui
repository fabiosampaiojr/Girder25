       <widget class="QLabel" name="html_espacamento_estribos">
        <property name="geometry">
         <rect>
          <x>20</x>
          <y>130</y>
          <width>941</width>
          <height>521</height>
         </rect>
        </property>
        <property name="text">
         <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;meta charset=&quot;utf-8&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
hr { height: 1px; border-width: 0; }
li.unchecked::marker { content: &quot;\2610&quot;; }
li.checked::marker { content: &quot;\2612&quot;; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Segoe UI'; font-size:9pt; font-weight:400; font-style:normal;&quot; bgcolor=&quot;#1e1e2e&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:16px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#1e1e1e;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:14pt; font-weight:700; color:#90caf9;&quot;&gt;📏 Espaçamento dos Estribos &lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:10pt; color:#b0bec5;&quot;&gt;NBR 6118:2023 – Item 18.3.4.1 &lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:10px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#252525;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:12pt; color:#b0bec5; background-color:#252525;&quot;&gt;Dados de Entrada &lt;/span&gt;&lt;/p&gt;
&lt;table border=&quot;0&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; border-collapse:collapse;&quot; cellspacing=&quot;2&quot; cellpadding=&quot;0&quot;&gt;
&lt;tr&gt;
&lt;td style=&quot; padding-left:0; padding-right:0; padding-top:4; padding-bottom:4;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#b0bec5;&quot;&gt;A&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#b0bec5; vertical-align:sub;&quot;&gt;sw&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#b0bec5;&quot;&gt;/s necessário&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;
&lt;td style=&quot; padding-left:0; padding-right:0; padding-top:4; padding-bottom:4;&quot;&gt;
&lt;p align=&quot;right&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-weight:700; color:#90caf9;&quot;&gt;21.00 cm²/m&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;
&lt;td style=&quot; padding-left:0; padding-right:0; padding-top:4; padding-bottom:4;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#b0bec5;&quot;&gt;Altura útil (d)&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;
&lt;td style=&quot; padding-left:0; padding-right:0; padding-top:4; padding-bottom:4;&quot;&gt;
&lt;p align=&quot;right&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-weight:700; color:#90caf9;&quot;&gt;155.00 cm&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;
&lt;td style=&quot; padding-left:0; padding-right:0; padding-top:4; padding-bottom:4;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#b0bec5;&quot;&gt;Diâmetro do estribo (ϕ)&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;
&lt;td style=&quot; padding-left:0; padding-right:0; padding-top:4; padding-bottom:4;&quot;&gt;
&lt;p align=&quot;right&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-weight:700; color:#90caf9;&quot;&gt;8 mm&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;
&lt;td style=&quot; padding-left:0; padding-right:0; padding-top:4; padding-bottom:4;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#b0bec5;&quot;&gt;Número de ramos&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;
&lt;td style=&quot; padding-left:0; padding-right:0; padding-top:4; padding-bottom:4;&quot;&gt;
&lt;p align=&quot;right&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-weight:700; color:#90caf9;&quot;&gt;2&lt;/span&gt;&lt;/p&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:10px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#252525;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:12pt; color:#b0bec5; background-color:#252525;&quot;&gt;Cálculo do Espaçamento &lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:10px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#252525;&quot;&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:11pt; color:#e0e0e0; background-color:#252525;&quot;&gt;1) Área de uma barra: A₁ = π·ϕ²/4 = π·(0.800)²/4 = 0.5027 cm²&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:11pt; color:#e0e0e0;&quot;&gt;&lt;br /&gt;2) Área total do estribo: A&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:11pt; color:#e0e0e0; vertical-align:sub;&quot;&gt;est&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:11pt; color:#e0e0e0;&quot;&gt; = n_ramos · A₁ = 2 · 0.5027 = 1.0053 cm²&lt;br /&gt;3) Espaçamento calculado: s&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:11pt; color:#e0e0e0; vertical-align:sub;&quot;&gt;calc&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:11pt; color:#e0e0e0;&quot;&gt; = (A&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:11pt; color:#e0e0e0; vertical-align:sub;&quot;&gt;est&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:11pt; color:#e0e0e0;&quot;&gt; / A&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:11pt; color:#e0e0e0; vertical-align:sub;&quot;&gt;sw&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:11pt; color:#e0e0e0;&quot;&gt;) · 100&lt;br /&gt;   = (1.0053 / 21.00) · 100 = 4.787 cm &lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:10px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#252525;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#888888; background-color:#252525;&quot;&gt;Arredondamento para baixo com tolerância de 0,5 cm:&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#888888;&quot;&gt;&lt;br /&gt;s&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#888888; vertical-align:sub;&quot;&gt;calculado&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#888888;&quot;&gt; = 4.787 cm → floor(4.787 × 2) / 2 = 4.5 cm &lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;center&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#1e3a2f;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:11pt; color:#b0bec5;&quot;&gt;ESPAÇAMENTO FINAL (arredondado p/ 0,5 cm)&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#e0e0e0;&quot;&gt;&lt;br /&gt;&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:18pt; font-weight:700; color:#4ade80;&quot;&gt;s = 4.5 cm &lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:16px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#252525;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:10pt; color:#b0bec5;&quot;&gt;Espaçamento máximo permitido (NBR 6118:2023, 18.3.4.1):&lt;br /&gt;s&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:10pt; color:#b0bec5; vertical-align:sub;&quot;&gt;max&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:10pt; color:#b0bec5;&quot;&gt; = min(0,6·d ; 30 cm) = min(0,6·155.0 ; 30) = 30 cm &lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;right&quot; style=&quot; margin-top:14px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#1e1e1e;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#888888; background-color:#1e1e1e;&quot;&gt;d = 155.00 cm  |  f&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#888888; vertical-align:sub;&quot;&gt;yk&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#888888;&quot;&gt; = 500.0 MPa &lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
