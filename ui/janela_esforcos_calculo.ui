&lt;p align=&quot;center&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#252525;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:11pt; font-weight:700; color:#e0e0e0;&quot;&gt;Mínimo em Apoio B (60.00 m):&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:11pt; color:#e0e0e0;&quot;&gt; &lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#e0e0e0;&quot;&gt;&lt;br /&gt;&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0;&quot;&gt;R&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0; vertical-align:sub;&quot;&gt;min&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0;&quot;&gt; = &lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e57373;&quot;&gt;-200.00 kN&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0;&quot;&gt;  |  R&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0; vertical-align:sub;&quot;&gt;max&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0;&quot;&gt; = &lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#81c784;&quot;&gt;+50.00 kN&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0;&quot;&gt; &lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;center&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'sans-serif'; font-size:11.5pt; font-weight:700; color:#ffffff;&quot;&gt;Convenção:&lt;/span&gt;&lt;span style=&quot; font-family:'sans-serif'; font-size:10pt; color:#e0e0e0;&quot;&gt; &lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;center&quot; style=&quot; margin-top:6px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'sans-serif'; font-size:10pt; font-weight:700; color:#81c784;&quot;&gt;(+) Para cima:&lt;/span&gt;&lt;span style=&quot; font-family:'sans-serif'; font-size:10pt; color:#e0e0e0;&quot;&gt; Reação vertical ascendente. &lt;br /&gt;&lt;/span&gt;&lt;span style=&quot; font-family:'sans-serif'; font-size:10pt; font-weight:700; color:#e57373;&quot;&gt;(-) Para baixo:&lt;/span&gt;&lt;span style=&quot; font-family:'sans-serif'; font-size:10pt; color:#e0e0e0;&quot;&gt; Reação vertical descendente. &lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
