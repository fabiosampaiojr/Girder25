       <property name="title">
        <string>Estados Limite de Cálculo</string>
       </property>
       <widget class="QLabel" name="label">
        <property name="geometry">
         <rect>
          <x>160</x>
          <y>20</y>
          <width>651</width>
          <height>411</height>
         </rect>
        </property>
        <property name="text">
         <string>&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;pt-br&quot;&gt;
&lt;head&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0, user-scalable=yes&quot;&gt;
    &lt;title&gt;Combinações de Esforços - NBR 6118:2023&lt;/title&gt;
    &lt;style&gt;
        /* Pequeno reset para garantir consistência entre navegadores */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background-color: #2b2b2b;
            color: #ffffff;
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            margin: 0;
            padding: 24px 20px;
            line-height: 1.4;
        }
        /* Estilos globais para melhor legibilidade dos símbolos matemáticos */
        .math-equation {
            font-family: 'Times New Roman', 'Georgia', serif;
            font-size: 18pt;
            padding: 28px 20px;
            text-align: center;
            background-color: rgba(255, 255, 255, 0.04);
            border-radius: 12px;
            border: 1px solid #4a4a4a;
            transition: all 0.2s;
            word-break: break-word;
            letter-spacing: 0.3px;
        }
        /* Bloco de título com destaque lateral */
        .section-title {
            color: #f1c40f;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.3px;
            margin-bottom: 16px;
            border-left: 4px solid #f1c40f;
            padding-left: 14px;
            text-transform: none;
        }
        /* Cada bloco principal (ELU / ELS) com espaçamento bem definido */
        .block-equation {
            margin-bottom: 52px;   /* Espaço generoso entre os blocos de equação */
        }
        /* Último bloco de equação não precisa de margem extra inferior se houver legenda,
           mas mantemos consistência; a legenda terá seu próprio espaçamento superior */
        .block-equation:last-of-type {
            margin-bottom: 48px;
        }
        /* Container da legenda - totalmente diferente do fundo das equações */
        .legend-container {
            background-color: #212121;  /* tom escuro sólido, diferente do fundo translúcido das equações */
            border: 1px solid #5f5f5f;
            border-radius: 14px;
            padding: 24px 28px;
            margin-top: 16px;
            margin-bottom: 28px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
            transition: background 0.2s;
        }
        /* Estilo do título da legenda, alinhado visualmente com os títulos das equações */
        .legend-heading {
            color: #f1c40f;
            font-weight: 700;
            font-size: 0.95rem;
            margin-bottom: 20px;
            border-left: 4px solid #f1c40f;
            padding-left: 14px;
            letter-spacing: 0.2px;
        }
        /* Cada linha de definição na legenda */
        .legend-item {
            margin-bottom: 12px;
            line-height: 1.55;
            font-size: 0.9rem;
            color: #e0e0e0;
        }
        .legend-item b {
            color: #f5f5f5;
            font-weight: 600;
        }
        .legend-item sub, .legend-item sup {
            font-size: 0.75rem;
        }
        /* pequeno ajuste para ícones matemáticos dentro da legenda */
        .legend-item i {
            font-style: italic;
        }
        /* rodapé de referência */
        .ref-footer {
            font-family: 'Segoe UI', sans-serif;
            font-size: 0.75rem;
            color: #f1c40f;
            text-align: right;
            border-top: 1px dashed #5a5a5a;
            padding-top: 14px;
            margin-top: 12px;
            opacity: 0.85;
        }
        /* responsividade: reduzir padding em telas pequenas */
        @media (max-width: 600px) {
            body {
                padding: 16px 12px;
            }
            .math-equation {
                font-size: 15pt;
                padding: 20px 12px;
            }
            .legend-container {
                padding: 18px 20px;
            }
            .block-equation {
                margin-bottom: 40px;
            }
        }
        /* pequena correção para garantir quebra de linha em equações longas */
        .math-equation br {
            display: none;
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;

    &lt;!-- BLOCO 1: ELU - Estado Limite Último --&gt;
    &lt;div class=&quot;block-equation&quot;&gt;
        &lt;div class=&quot;section-title&quot;&gt;
            ELU — Estado Limite Último: Combinação Normal
        &lt;/div&gt;
        &lt;div class=&quot;math-equation&quot;&gt;
            &lt;i&gt;F&lt;/i&gt;&lt;sub&gt;d&lt;/sub&gt; = &amp;gamma;&lt;sub&gt;g&lt;/sub&gt;&lt;i&gt;F&lt;/i&gt;&lt;sub&gt;gk&lt;/sub&gt; + 
            &amp;gamma;&lt;sub&gt;q&lt;/sub&gt; (&lt;i&gt;F&lt;/i&gt;&lt;sub&gt;q1k&lt;/sub&gt; + &amp;Sigma;&amp;psi;&lt;sub&gt;0j&lt;/sub&gt;&lt;i&gt;F&lt;/i&gt;&lt;sub&gt;qjk&lt;/sub&gt;) + 
            &amp;gamma;&lt;sub&gt;&amp;epsilon;q&lt;/sub&gt;&amp;psi;&lt;sub&gt;0&amp;epsilon;&lt;/sub&gt;&lt;i&gt;F&lt;/i&gt;&lt;sub&gt;&amp;epsilon;qk&lt;/sub&gt;
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;!-- BLOCO 2: ELS - Estado Limite de Serviço (Combinação Frequente) --&gt;
    &lt;div class=&quot;block-equation&quot;&gt;
        &lt;div class=&quot;section-title&quot;&gt;
            ELS — Estado Limite de Serviço: Combinação Frequente
        &lt;/div&gt;
        &lt;div class=&quot;math-equation&quot;&gt;
            &lt;i&gt;F&lt;/i&gt;&lt;sub&gt;d,ser&lt;/sub&gt; = &amp;Sigma;&lt;i&gt;F&lt;/i&gt;&lt;sub&gt;gi,k&lt;/sub&gt; + 
            &amp;psi;&lt;sub&gt;1&lt;/sub&gt;&lt;i&gt;F&lt;/i&gt;&lt;sub&gt;q1k&lt;/sub&gt; + &amp;Sigma;&amp;psi;&lt;sub&gt;2j&lt;/sub&gt;&lt;i&gt;F&lt;/i&gt;&lt;sub&gt;qj,k&lt;/sub&gt;
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;!-- LEGENDA: agora com fundo completamente distinto das equações, melhor hierarquia visual --&gt;
    &lt;div class=&quot;legend-container&quot;&gt;
        &lt;div class=&quot;legend-heading&quot;&gt;
            Legenda dos Componentes
        &lt;/div&gt;
        
        &lt;div class=&quot;legend-item&quot;&gt;
            &lt;b&gt;&lt;i&gt;F&lt;/i&gt;&lt;sub&gt;gk&lt;/sub&gt; / &lt;i&gt;F&lt;/i&gt;&lt;sub&gt;gi,k&lt;/sub&gt;:&lt;/b&gt; Esforços/Ações Permanentes (Peso Próprio, Pavimentação e Guarda-rodas)
        &lt;/div&gt;
        &lt;div class=&quot;legend-item&quot;&gt;
            &lt;b&gt;&lt;i&gt;F&lt;/i&gt;&lt;sub&gt;q1k&lt;/sub&gt;:&lt;/b&gt; Ação Variável Principal (Carga Móvel / Trem‑tipo)
        &lt;/div&gt;
        &lt;div class=&quot;legend-item&quot;&gt;
            &lt;b&gt;&lt;i&gt;F&lt;/i&gt;&lt;sub&gt;qjk&lt;/sub&gt; / &lt;i&gt;F&lt;/i&gt;&lt;sub&gt;&amp;epsilon;qk&lt;/sub&gt;:&lt;/b&gt; Ações Variáveis Secundárias e Efeitos de Recalque ou Temperatura
        &lt;/div&gt;
        &lt;div class=&quot;legend-item&quot;&gt;
            &lt;b&gt;&amp;gamma;&lt;sub&gt;g&lt;/sub&gt;, &amp;gamma;&lt;sub&gt;q&lt;/sub&gt;, &amp;gamma;&lt;sub&gt;&amp;epsilon;q&lt;/sub&gt;:&lt;/b&gt; Coeficientes de ponderação das ações (Majoradores)
        &lt;/div&gt;
        &lt;div class=&quot;legend-item&quot;&gt;
            &lt;b&gt;&amp;psi;&lt;sub&gt;0&lt;/sub&gt;, &amp;psi;&lt;sub&gt;1&lt;/sub&gt;, &amp;psi;&lt;sub&gt;2&lt;/sub&gt;:&lt;/b&gt; Fatores de redução para combinações (Simultaneidade e Frequência)
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;!-- Referência normativa --&gt;
    &lt;div class=&quot;ref-footer&quot;&gt;
        Referência: NBR 6118:2023
    &lt;/div&gt;

&lt;/body&gt;
&lt;/html&gt;</string>
        </property>
        <property name="textInteractionFlags">
         <set>Qt::TextInteractionFlag::TextSelectableByMouse</set>
        </property>
       </widget>
      </widget>
