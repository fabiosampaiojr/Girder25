        <property name="html">
         <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;meta charset=&quot;utf-8&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
hr { height: 1px; border-width: 0; }
li.unchecked::marker { content: &quot;\2610&quot;; }
li.checked::marker { content: &quot;\2612&quot;; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Segoe UI'; font-size:9pt; font-weight:400; font-style:normal;&quot; bgcolor=&quot;#1e1e1e&quot;&gt;
&lt;p align=&quot;center&quot; style=&quot; margin-top:0px; margin-bottom:14px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#252525;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:14pt; font-weight:700; color:#90caf9; background-color:#252525;&quot;&gt;φ·Cortante &lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;center&quot; style=&quot; margin-top:0px; margin-bottom:10px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; background-color:#252525;&quot;&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:11pt; font-weight:700; color:#e0e0e0;&quot;&gt;Máximo em S10 (45.00 m):&lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; font-size:11pt; color:#e0e0e0;&quot;&gt; &lt;/span&gt;&lt;span style=&quot; font-family:'Segoe UI','Arial','sans-serif'; color:#e0e0e0;&quot;&gt;&lt;br /&gt;&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0;&quot;&gt;φ·V&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0; vertical-align:sub;&quot;&gt;min&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0;&quot;&gt; = &lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e57373;&quot;&gt;-30.00 kN&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0;&quot;&gt;  |  φ·V&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0; vertical-align:sub;&quot;&gt;max&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0;&quot;&gt; = &lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#81c784;&quot;&gt;+850.00 kN&lt;/span&gt;&lt;span style=&quot; font-family:'Courier New','monospace'; font-size:12.5pt; font-weight:700; color:#e0e0e0;&quot;&gt; &lt;/span&gt;&lt;/p&gt;
